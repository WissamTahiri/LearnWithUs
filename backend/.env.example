# ============================================================
# .env.example — Modèle de variables d'environnement
# ============================================================
# Ce fichier sert de MODÈLE. Pour l'utiliser :
#   1. Copiez ce fichier : cp .env.example .env
#   2. Remplissez les valeurs dans le fichier .env
#
# IMPORTANT : Ne JAMAIS committer le fichier .env sur GitHub !
# Il contient des secrets (clés API, URLs privées).
# Le fichier .env.example (ce fichier) peut être commité car
# il ne contient PAS de vraies valeurs.
# ============================================================

# Port du serveur (Render le définit automatiquement en production)
PORT=3000

# URL du webhook n8n pour l'automatisation des emails d'inscription
# Renseigner après avoir créé le workflow sur Railway/n8n
# Exemple : https://votre-instance-n8n.railway.app/webhook/inscription
WEBHOOK_N8N_URL=

# URL du webhook n8n pour les messages du formulaire de contact
# Workflow : n8n-workflow-contact.json (à importer dans n8n)
# Exemple : https://votre-instance-n8n.railway.app/webhook/learnwithus-contact
WEBHOOK_N8N_CONTACT_URL=

# URL du front pour les règles CORS (optionnel en développement)
# En production, remplacer par l'URL Vercel du frontend
URL_FRONTEND=http://localhost:5500

# Token d'intégration Notion (secret_...)
# Créer une intégration sur notion.so/my-integrations
NOTION_TOKEN=

# ID de la base de données Notion "Inscriptions"
# Visible dans l'URL de la base : notion.so/XXXXXXXX...
NOTION_DATABASE_ID=

# ID de la base de données Notion "Comptes LearnWithUs"
# Base créée en Phase 4 pour stocker les comptes utilisateurs
NOTION_DATABASE_COMPTES_ID=

# Secret utilisé pour signer les jetons JWT de session
# Générer une chaîne aléatoire longue (ex : openssl rand -hex 32)
JWT_SECRET=
