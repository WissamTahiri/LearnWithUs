# Dépendances Node.js — ne PAS committer ce dossier
# npm install les recréera à partir de package.json
node_modules/

# Variables d'environnement — contient des secrets (clés API, URLs privées)
# Seul .env.example (sans vraies valeurs) est committé
.env

# Fichiers système générés par l'OS
.DS_Store
Thumbs.db

# Fichiers de configuration IDE
.vscode/
.idea/

# Fichiers de contexte / notes locales
.claude/
CLAUDE.md
*.local.md

# Sécurité : tout config.php contient des secrets (Notion token, APP_SECRET)
# Le seul committé est config.example.php (modèle sans valeurs réelles)
config.php
backend-php/config.php

# Vidéos de formation (assets lourds .mp4) — déployées via FileZilla, PAS via Git
frontend/videos/
